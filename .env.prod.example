# Production environment variables
# Copy to .env.prod and fill in real values

DJANGO_SECRET_KEY=change-me-to-a-random-64-char-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com

POSTGRES_DB=projectfinance
POSTGRES_USER=projectfinance
POSTGRES_PASSWORD=change-me-to-a-strong-password

OTEL_SERVICE_NAME=project-finance-azure-simple
OTEL_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <your-grafana-cloud-token>

DOMAIN=yourdomain.com
